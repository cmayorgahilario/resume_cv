---
// Header.astro — Sticky navigation header
// Tokens consumed: --bg-primary, --border-default, --color-primary, --text-heading,
//                  --text-secondary, --text-on-primary, --bg-alt
---

<header class="sticky top-0 z-50 w-full bg-[var(--bg-primary)] border-b border-[var(--border-default)]">
  <div class="max-w-[1440px] mx-auto px-20 py-5 flex items-center justify-between">

    <!-- Logo group -->
    <div class="flex items-center gap-2">
      <div
        class="w-9 h-9 bg-[var(--color-primary-bg)] rounded flex items-center justify-center shrink-0"
        aria-hidden="true"
      >
        <span class="text-[var(--text-on-primary)] text-base font-bold leading-none">CM</span>
      </div>
      <span class="text-[var(--text-heading)] text-base font-semibold">Carlos Mayorga</span>
    </div>

    <!-- Primary navigation -->
    <nav aria-label="Navegación principal">
      <ul class="flex items-center gap-8 list-none m-0 p-0">
        <li>
          <a
            href="#inicio"
            class="text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
            aria-current="page"
          >Inicio</a>
        </li>
        <li>
          <a
            href="#sobre-mi"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Sobre Mí</a>
        </li>
        <li>
          <a
            href="#experiencia"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Experiencia</a>
        </li>
        <li>
          <a
            href="#habilidades"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Habilidades</a>
        </li>
        <li>
          <a
            href="#proyectos"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Proyectos</a>
        </li>
        <li>
          <a
            href="#educacion"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Educación</a>
        </li>
        <li>
          <a
            href="#contacto"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Contacto</a>
        </li>
      </ul>
    </nav>

    <!-- Right group: theme toggle + CTA -->
    <div class="flex items-center gap-4">

      <!-- Theme toggle pill — functional button (M002) -->
      <button
        type="button"
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="bg-[var(--bg-alt)] dark:bg-white rounded-full p-[3px] flex gap-[2px] cursor-pointer border-none outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
      >
        <!-- Sun icon (active in light mode) -->
        <div
          id="sun-icon"
          class="w-[26px] h-[26px] rounded-full flex items-center justify-center"
          aria-hidden="true"
        >
          <!-- Sun SVG: circle + 8 rays -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </div>

        <!-- Moon icon (active in dark mode) -->
        <div
          id="moon-icon"
          class="w-[26px] h-[26px] rounded-full flex items-center justify-center"
          aria-hidden="true"
        >
          <!-- Moon SVG: crescent -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </div>
      </button>

      <!-- CTA: Download CV -->
      <a
        href="#"
        class="bg-[var(--color-primary-bg)] text-[var(--text-on-primary)] rounded-md px-6 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity"
        aria-label="Descargar CV de Carlos Mayorga"
      >
        Descargar CV
      </a>

    </div>
  </div>
</header>

<script>
  // Theme toggle: read initial state, wire click handler, keep icon visual in sync
  const ACCENT_COLOR = getComputedStyle(document.documentElement)
    .getPropertyValue('--color-accent').trim() || '#7c3aed';
  const TEXT_ON_PRIMARY = '#ffffff';
  const TEXT_SECONDARY = getComputedStyle(document.documentElement)
    .getPropertyValue('--text-secondary').trim() || '#6b7280';

  function updateToggleVisual() {
    const isDark = document.documentElement.classList.contains('dark');
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');

    if (!sunIcon || !moonIcon) return;

    if (isDark) {
      // Moon is active in dark mode
      moonIcon.style.backgroundColor = ACCENT_COLOR;
      moonIcon.style.color = TEXT_ON_PRIMARY;
      sunIcon.style.backgroundColor = 'transparent';
      sunIcon.style.color = TEXT_SECONDARY;
    } else {
      // Sun is active in light mode
      sunIcon.style.backgroundColor = ACCENT_COLOR;
      sunIcon.style.color = TEXT_ON_PRIMARY;
      moonIcon.style.backgroundColor = 'transparent';
      moonIcon.style.color = TEXT_SECONDARY;
    }
  }

  // Set correct initial visual immediately
  updateToggleVisual();

  // Wire click handler
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateToggleVisual();
    });
  }
</script>
