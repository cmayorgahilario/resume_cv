---
// Header.astro — Sticky navigation header (mobile-responsive with hamburger overlay)
// Tokens consumed: --bg-primary, --border-default, --color-primary, --text-heading,
//                  --text-secondary, --text-on-primary, --bg-alt, --color-primary-bg,
//                  --color-accent, --color-accent-overlay-light
---

<header class="sticky top-0 z-50 w-full bg-[var(--bg-primary)] border-b border-[var(--border-default)]">
  <div class="max-w-[1440px] mx-auto px-6 md:px-20 py-5 flex items-center justify-between">

    <!-- Logo group -->
    <div class="flex items-center gap-2">
      <div
        class="w-9 h-9 bg-[var(--color-primary-bg)] rounded flex items-center justify-center shrink-0"
        aria-hidden="true"
      >
        <span class="text-[var(--text-on-primary)] text-base font-bold leading-none">CM</span>
      </div>
      <span class="text-[var(--text-heading)] text-base font-semibold">Carlos Mayorga</span>
    </div>

    <!-- Primary navigation (desktop only) -->
    <nav aria-label="Navegación principal">
      <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
        <li>
          <a
            href="#inicio"
            class="text-sm font-medium text-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
            aria-current="page"
          >Inicio</a>
        </li>
        <li>
          <a
            href="#sobre-mi"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Sobre Mí</a>
        </li>
        <li>
          <a
              href="#habilidades"
              class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Habilidades</a>
        </li>
        <li>
          <a
            href="#proyectos"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Proyectos</a>
        </li>
        <li>
          <a
              href="#experiencia"
              class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Experiencia</a>
        </li>
        <li>
          <a
            href="#educacion"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Educación</a>
        </li>
        <li>
          <a
            href="#contacto"
            class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
          >Contacto</a>
        </li>
      </ul>
    </nav>

    <!-- Right group: theme toggle + CTA (desktop) + mobile controls -->
    <div class="flex items-center gap-4">

      <!-- Mobile bare theme icon (visible on mobile only) -->
      <button
        type="button"
        id="theme-toggle-mobile"
        aria-label="Cambiar tema"
        class="flex md:hidden items-center justify-center w-10 h-10 cursor-pointer border-none bg-transparent text-[var(--text-heading)]"
      >
        <!-- Moon icon (shown in light mode on mobile) -->
        <span id="mobile-moon-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </span>
        <!-- Sun icon (shown in dark mode on mobile) -->
        <span id="mobile-sun-icon" aria-hidden="true" style="display:none">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </span>
      </button>

      <!-- Hamburger button (visible on mobile only) -->
      <button
        type="button"
        id="hamburger-btn"
        aria-label="Abrir menú"
        class="flex md:hidden items-center justify-center w-10 h-10 cursor-pointer border-none bg-transparent text-[var(--text-heading)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <!-- Theme toggle pill — desktop only -->
      <button
        type="button"
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="hidden md:flex bg-[var(--bg-alt)] dark:bg-white rounded-full p-[3px] gap-[2px] cursor-pointer border-none outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)]"
      >
        <!-- Sun icon (active in light mode) -->
        <div
          id="sun-icon"
          class="w-[26px] h-[26px] rounded-full flex items-center justify-center"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </div>

        <!-- Moon icon (active in dark mode) -->
        <div
          id="moon-icon"
          class="w-[26px] h-[26px] rounded-full flex items-center justify-center"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </div>
      </button>

      <!-- CTA: Download CV (desktop only) -->
      <a
        href="https://drive.google.com/file/d/10lGNZ5J3l_LcxfvfNNqwBOFz8_EA8NT_/view?usp=drive_link"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex bg-[var(--color-primary-bg)] text-[var(--text-on-primary)] rounded-md px-6 py-2.5 text-sm font-semibold hover:opacity-90 transition-opacity"
        aria-label="Descargar CV de Carlos Mayorga"
      >
        Descargar CV
      </a>

    </div>
  </div>
</header>

<!-- Full-screen mobile overlay menu (z-[60] sits above sticky header z-50) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-[var(--bg-primary)] hidden flex-col"
  aria-label="Menú de navegación móvil"
  role="dialog"
  aria-modal="true"
>
  <!-- Overlay top bar: logo + close button -->
  <div class="px-6 py-5 flex items-center justify-between border-b border-[var(--border-default)]">
    <div class="flex items-center gap-2">
      <div
        class="w-9 h-9 bg-[var(--color-primary-bg)] rounded flex items-center justify-center shrink-0"
        aria-hidden="true"
      >
        <span class="text-[var(--text-on-primary)] text-base font-bold leading-none">CM</span>
      </div>
      <span class="text-[var(--text-heading)] text-base font-semibold">Carlos Mayorga</span>
    </div>
    <button
      type="button"
      id="close-menu-btn"
      aria-label="Cerrar menú"
      class="flex items-center justify-center w-10 h-10 cursor-pointer border-none bg-transparent text-[var(--text-heading)]"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Overlay nav links -->
  <nav aria-label="Navegación móvil" class="flex-1 overflow-y-auto px-6 py-4">
    <ul class="list-none m-0 p-0 flex flex-col">
      <li>
        <a
          href="#inicio"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--color-primary)] border-b border-[var(--border-default)]"
          aria-current="page"
        >
          <span>Inicio</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-primary-bg)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#sobre-mi"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors border-b border-[var(--border-default)]"
        >
          <span>Sobre Mí</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#experiencia"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors border-b border-[var(--border-default)]"
        >
          <span>Experiencia</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#habilidades"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors border-b border-[var(--border-default)]"
        >
          <span>Habilidades</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#proyectos"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors border-b border-[var(--border-default)]"
        >
          <span>Proyectos</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#educacion"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors border-b border-[var(--border-default)]"
        >
          <span>Educación</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
      <li>
        <a
          href="#contacto"
          class="overlay-nav-link flex items-center justify-between py-3 text-lg font-medium text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
        >
          <span>Contacto</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </li>
    </ul>
  </nav>

  <!-- Overlay bottom: Download CV CTA -->
  <div class="px-6 py-6 border-t border-[var(--border-default)]">
    <a
      href="https://drive.google.com/file/d/10lGNZ5J3l_LcxfvfNNqwBOFz8_EA8NT_/view?usp=drive_link"
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full text-center bg-[var(--color-primary-bg)] text-[var(--text-on-primary)] rounded-md px-6 py-3 text-sm font-semibold hover:opacity-90 transition-opacity"
      aria-label="Descargar CV de Carlos Mayorga"
    >
      Descargar CV
    </a>
  </div>

  <!-- Social icons row -->
  <div class="social-icons-row px-6 pb-6 flex items-center justify-center gap-4">
    <a
      href="https://www.linkedin.com/in/cmayorgahilario/"
      target="_blank"
      rel="noopener noreferrer"
      class="w-10 h-10 rounded-full bg-[var(--bg-alt)] flex items-center justify-center text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
      aria-label="LinkedIn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
    </a>
    <a
      href="https://github.com/cmayorgahilario"
      target="_blank"
      rel="noopener noreferrer"
      class="w-10 h-10 rounded-full bg-[var(--bg-alt)] flex items-center justify-center text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
      aria-label="GitHub"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
    </a>
    <a
      href="mailto:cmayorgahilario@gmail.com"
      class="w-10 h-10 rounded-full bg-[var(--bg-alt)] flex items-center justify-center text-[var(--text-secondary)] hover:text-[var(--color-primary)] transition-colors"
      aria-label="Email"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
    </a>
  </div>
</div>

<script>
  // ── Theme toggle ──────────────────────────────────────────────────────────────
  const ACCENT_COLOR = getComputedStyle(document.documentElement)
    .getPropertyValue('--color-accent').trim() || '#7c3aed';
  const TEXT_ON_PRIMARY = '#ffffff';
  const TEXT_SECONDARY = getComputedStyle(document.documentElement)
    .getPropertyValue('--text-secondary').trim() || '#6b7280';

  function updateToggleVisual() {
    const isDark = document.documentElement.classList.contains('dark');

    // Desktop pill toggle icons
    const sunIcon = document.getElementById('sun-icon');
    const moonIcon = document.getElementById('moon-icon');
    if (sunIcon && moonIcon) {
      if (isDark) {
        moonIcon.style.backgroundColor = ACCENT_COLOR;
        moonIcon.style.color = TEXT_ON_PRIMARY;
        sunIcon.style.backgroundColor = 'transparent';
        sunIcon.style.color = TEXT_SECONDARY;
      } else {
        sunIcon.style.backgroundColor = ACCENT_COLOR;
        sunIcon.style.color = TEXT_ON_PRIMARY;
        moonIcon.style.backgroundColor = 'transparent';
        moonIcon.style.color = TEXT_SECONDARY;
      }
    }

    // Mobile bare icon: show moon in light mode, sun in dark mode
    const mobileMoonIcon = document.getElementById('mobile-moon-icon');
    const mobileSunIcon = document.getElementById('mobile-sun-icon');
    if (mobileMoonIcon && mobileSunIcon) {
      mobileMoonIcon.style.display = isDark ? 'none' : 'inline';
      mobileSunIcon.style.display = isDark ? 'inline' : 'none';
    }
  }

  // Set correct initial visual immediately
  updateToggleVisual();

  // Wire desktop pill toggle
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateToggleVisual();
    });
  }

  // Wire mobile bare icon toggle
  const toggleMobile = document.getElementById('theme-toggle-mobile');
  if (toggleMobile) {
    toggleMobile.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateToggleVisual();
    });
  }

  // ── Hamburger menu ────────────────────────────────────────────────────────────
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const overlayNavLinks = document.querySelectorAll('.overlay-nav-link');

  function openMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove('hidden');
    mobileMenu.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.add('hidden');
    mobileMenu.classList.remove('flex');
    document.body.style.overflow = '';
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', openMenu);
  }

  if (closeMenuBtn) {
    closeMenuBtn.addEventListener('click', closeMenu);
  }

  overlayNavLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
