---
// Footer — dark-surface section with brand, navigation, and social columns
---

<footer class="bg-[var(--bg-footer)] py-12 px-6 md:px-20">
  <div class="max-w-[1440px] mx-auto flex flex-col gap-8">

    <!-- Top row: brand + nav columns -->
    <div class="flex flex-col md:flex-row gap-8 md:gap-12">

      <!-- Brand column -->
      <div class="flex flex-col gap-3 w-full md:w-[300px] md:min-w-[300px] md:max-w-[300px]">
        <!-- Logo + name -->
        <div class="flex items-center gap-3">
          <div
            class="w-8 h-8 bg-[var(--color-primary-bg)] rounded flex items-center justify-center shrink-0"
          >
            <span class="text-[var(--text-on-primary)] text-sm font-bold leading-none">CM</span>
          </div>
          <span class="text-[var(--text-on-primary)] text-[15px] font-semibold leading-none">
            Carlos Mayorga
          </span>
        </div>
        <!-- Description -->
        <p class="text-[var(--text-footer-link)] text-[13px] leading-relaxed m-0">
          Tech Lead &amp; Software Engineer con más de 10 años de experiencia
          construyendo soluciones escalables.
        </p>
      </div>

      <!-- NAVEGACIÓN column -->
      <div class="flex flex-col gap-3">
        <p class="text-[var(--text-footer-muted)] text-[11px] font-semibold uppercase tracking-[1px] m-0">
          NAVEGACIÓN
        </p>
        <nav class="flex flex-col gap-2">
          <a
            href="#inicio"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            Inicio
          </a>
          <a
            href="#sobre-mi"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            Sobre Mí
          </a>
          <a
            href="#experiencia"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            Experiencia
          </a>
          <a
            href="#habilidades"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            Habilidades
          </a>
        </nav>
      </div>

      <!-- SOCIAL column -->
      <div class="flex flex-col gap-3">
        <p class="text-[var(--text-footer-muted)] text-[11px] font-semibold uppercase tracking-[1px] m-0">
          SOCIAL
        </p>
        <nav class="flex flex-col gap-2">
          <a
            href="#"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            LinkedIn
          </a>
          <a
            href="#"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            GitHub
          </a>
          <a
            href="#"
            class="text-[var(--text-footer-link)] text-[13px] hover:text-[var(--text-on-primary)] hover:font-medium transition-colors no-underline"
          >
            Twitter
          </a>
        </nav>
      </div>

    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-[var(--divider)]"></div>

    <!-- Copyright -->
    <p class="text-[var(--text-footer-muted)] text-xs m-0">
      © 2025 Carlos Alberto Mayorga Hilario. Todos los derechos reservados.
    </p>

  </div>
</footer>
