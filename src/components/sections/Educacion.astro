---
// Educacion section — degree panel with stats column, 3 cert rows (alternating indigo/amber), and summary bar
---

<section id="educacion" class="bg-[var(--bg-indigo-soft)] py-20 px-20">
  <div class="max-w-[1440px] mx-auto flex flex-col gap-12">

    <!-- Section header: label, title, subtitle — vertical centered -->
    <div class="flex flex-col gap-4 items-center text-center">
      <span class="text-xs font-semibold tracking-[2px] text-[var(--color-primary)]">EDUCACIÓN Y CERTIFICACIONES</span>
      <h2 class="text-[36px] font-bold tracking-[-0.5px] text-[var(--text-heading)]">
        Cada certificación, un nuevo nivel
      </h2>
      <p class="text-[16px] text-[var(--text-secondary)] max-w-[750px]">
        Un recorrido de formación continua que combina fundamentos de ingeniería con expertise en agilidad y diseño
      </p>
    </div>

    <!-- Degree panel: large card with left indigo stripe -->
    <div class="bg-[var(--bg-card)] rounded-[16px] border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] overflow-hidden flex flex-row">

      <!-- Left indigo stripe -->
      <div class="w-[5px] bg-[var(--color-primary)] self-stretch flex-shrink-0"></div>

      <!-- Content area -->
      <div class="p-[28px_32px] flex flex-row gap-[32px] items-start flex-1">

        <!-- Left content: icon row, title, university, description, pills -->
        <div class="flex-1 flex flex-col gap-4">

          <!-- Label row: icon + label text + year pill -->
          <div class="flex items-center gap-3 flex-wrap">
            <!-- Graduation cap icon in circle -->
            <div class="w-10 h-10 bg-[var(--bg-indigo-pill)] rounded-full flex items-center justify-center flex-shrink-0">
              <!-- lucide: graduation-cap -->
              <svg
                class="w-[20px] h-[20px] text-[var(--color-primary)]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                <path d="M6 12v5c3 3 9 3 12 0v-5"/>
              </svg>
            </div>
            <span class="text-[11px] font-semibold tracking-[2px] text-[var(--color-primary)]">GRADO UNIVERSITARIO</span>
            <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">2012 — 2017</span>
          </div>

          <!-- Degree title -->
          <h3 class="text-[22px] font-bold text-[var(--text-heading)]">Ingeniería de Sistemas</h3>

          <!-- University -->
          <p class="text-[14px] text-[var(--text-secondary)]">Universidad Nacional del Callao (UNAC)</p>

          <!-- Description -->
          <p class="text-[14px] text-[var(--text-secondary)] leading-[1.6]">
            Formación integral con especialización en arquitectura de software, sistemas distribuidos y diseño de bases de datos. Tesis: Arquitectura de microservicios para sistemas de alta disponibilidad.
          </p>

          <!-- Skill pills -->
          <div class="flex flex-wrap gap-2">
            <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">Arquitectura</span>
            <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">Distribuidos</span>
            <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">Bases de Datos</span>
          </div>

        </div>

        <!-- Right stats column -->
        <div class="w-[180px] flex-shrink-0 flex flex-col items-center gap-4">

          <!-- Stat 1 -->
          <div class="flex flex-col items-center text-center py-3">
            <span class="text-[24px] font-extrabold text-[var(--color-primary)]">Top 10%</span>
            <span class="text-[11px] text-[var(--text-secondary)]">de la promoción</span>
          </div>

          <!-- Divider -->
          <div class="w-[60px] h-px bg-[var(--border-default)]"></div>

          <!-- Stat 2 -->
          <div class="flex flex-col items-center text-center py-3">
            <span class="text-[24px] font-extrabold text-[var(--color-primary)]">5 años</span>
            <span class="text-[11px] text-[var(--text-secondary)]">formación</span>
          </div>

        </div>

      </div>
    </div>

    <!-- Certification rows -->
    <div class="flex flex-col gap-4">

      <!-- Cert 1: Certified ScrumMaster (CSM) — amber stripe -->
      <div class="bg-[var(--bg-card)] rounded-[12px] border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] overflow-hidden flex flex-row">
        <!-- Amber left stripe -->
        <div class="w-[5px] bg-[var(--color-amber)] self-stretch flex-shrink-0"></div>
        <!-- Content -->
        <div class="p-[20px_28px] flex flex-row items-center justify-between flex-1 gap-4">
          <!-- Left group: icon + text -->
          <div class="flex flex-row items-center gap-4">
            <!-- Award icon in amber bg -->
            <div class="w-11 h-11 bg-[var(--bg-amber-pill)] rounded-[10px] flex items-center justify-center flex-shrink-0">
              <!-- lucide: award -->
              <svg
                class="w-[22px] h-[22px] text-[var(--color-amber)]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="8" r="6"/>
                <path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
              </svg>
            </div>
            <!-- Title + issuer -->
            <div class="flex flex-col gap-0.5">
              <span class="text-[17px] font-semibold text-[var(--text-heading)]">Certified ScrumMaster (CSM)</span>
              <span class="text-[13px] text-[var(--text-secondary)] max-w-[500px]">Scrum Alliance · 2020 — Metodologías ágiles para equipos de alto rendimiento</span>
            </div>
          </div>
          <!-- Right: category pill -->
          <span class="text-[11px] font-semibold text-[var(--text-amber-dark)] bg-[var(--bg-amber-pill)] rounded-full py-1 px-3 flex-shrink-0">Agile</span>
        </div>
      </div>

      <!-- Cert 2: Certified Agile Leadership I (CAL I) — indigo stripe -->
      <div class="bg-[var(--bg-card)] rounded-[12px] border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] overflow-hidden flex flex-row">
        <!-- Indigo left stripe -->
        <div class="w-[5px] bg-[var(--color-primary)] self-stretch flex-shrink-0"></div>
        <!-- Content -->
        <div class="p-[20px_28px] flex flex-row items-center justify-between flex-1 gap-4">
          <!-- Left group: icon + text -->
          <div class="flex flex-row items-center gap-4">
            <!-- Shield-check icon in indigo bg -->
            <div class="w-11 h-11 bg-[var(--bg-indigo-pill)] rounded-[10px] flex items-center justify-center flex-shrink-0">
              <!-- lucide: shield-check -->
              <svg
                class="w-[22px] h-[22px] text-[var(--color-primary)]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
            </div>
            <!-- Title + issuer -->
            <div class="flex flex-col gap-0.5">
              <span class="text-[17px] font-semibold text-[var(--text-heading)]">Certified Agile Leadership I (CAL I)</span>
              <span class="text-[13px] text-[var(--text-secondary)] max-w-[500px]">Scrum Alliance · 2021 — Liderazgo transformacional en organizaciones tech</span>
            </div>
          </div>
          <!-- Right: category pill -->
          <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3 flex-shrink-0">Leadership</span>
        </div>
      </div>

      <!-- Cert 3: UX/UI Designer — amber stripe -->
      <div class="bg-[var(--bg-card)] rounded-[12px] border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] overflow-hidden flex flex-row">
        <!-- Amber left stripe -->
        <div class="w-[5px] bg-[var(--color-amber)] self-stretch flex-shrink-0"></div>
        <!-- Content -->
        <div class="p-[20px_28px] flex flex-row items-center justify-between flex-1 gap-4">
          <!-- Left group: icon + text -->
          <div class="flex flex-row items-center gap-4">
            <!-- Palette icon in amber bg -->
            <div class="w-11 h-11 bg-[var(--bg-amber-pill)] rounded-[10px] flex items-center justify-center flex-shrink-0">
              <!-- lucide: palette -->
              <svg
                class="w-[22px] h-[22px] text-[var(--color-amber)]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/>
                <circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/>
                <circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/>
                <circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/>
                <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>
              </svg>
            </div>
            <!-- Title + issuer -->
            <div class="flex flex-col gap-0.5">
              <span class="text-[17px] font-semibold text-[var(--text-heading)]">UX/UI Designer</span>
              <span class="text-[13px] text-[var(--text-secondary)] max-w-[500px]">Toulouse Lautrec · 2019 — Diseño centrado en el usuario para productos digitales</span>
            </div>
          </div>
          <!-- Right: category pill -->
          <span class="text-[11px] font-semibold text-[var(--text-amber-dark)] bg-[var(--bg-amber-pill)] rounded-full py-1 px-3 flex-shrink-0">Design</span>
        </div>
      </div>

    </div>

    <!-- Summary bar: trending-up icon + text + platform pills -->
    <div class="bg-[var(--bg-card)] rounded-[12px] border border-[var(--border-default)] p-[20px_32px] flex flex-row items-center justify-between gap-4">

      <!-- Left: icon + text -->
      <div class="flex items-center gap-3">
        <!-- lucide: trending-up -->
        <svg
          class="w-[20px] h-[20px] text-[var(--color-primary)] flex-shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
          <polyline points="16 7 22 7 22 13"/>
        </svg>
        <span class="text-[14px] font-medium text-[var(--text-heading)]">Aprendizaje continuo: +500 horas en cloud, reactive systems y clean code</span>
      </div>

      <!-- Right: platform pills -->
      <div class="flex flex-row gap-2 flex-shrink-0">
        <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">Udemy</span>
        <span class="text-[11px] font-semibold text-[var(--text-amber-dark)] bg-[var(--bg-amber-pill)] rounded-full py-1 px-3">Pluralsight</span>
        <span class="text-[11px] font-semibold text-[var(--color-primary)] bg-[var(--bg-indigo-pill)] rounded-full py-1 px-3">Coursera</span>
      </div>

    </div>

  </div>
</section>
