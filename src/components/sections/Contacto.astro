---
// Contacto section — two-column layout: static form left, contact info card right
// Form is visual-only (no action, no JS handler) — R021 deferred
---

<section id="contacto" class="bg-[var(--bg-primary)] py-12 md:py-20 px-6 md:px-20">
  <div class="max-w-[1440px] mx-auto flex flex-col gap-12">

    <!-- Section header: label, title, subtitle — vertical centered -->
    <div class="flex flex-col gap-4 items-center text-center">
      <span class="text-xs font-semibold tracking-[1px] text-[var(--color-primary)]">CONTACTO</span>
      <h2 class="text-[28px] md:text-[36px] font-bold text-[var(--text-heading)]">Hablemos</h2>
      <p class="text-[16px] text-[var(--text-secondary)]">¿Tienes un proyecto en mente? Estoy disponible para colaborar.</p>
    </div>

    <!-- 2-column grid: form left, contact info right -->
    <div class="flex flex-col md:flex-row gap-8 md:gap-[32px] items-start">

      <!-- Left column: form -->
      <div class="flex-1">
        <form class="rounded-[8px] border-[1.5px] border-[var(--border-default)] p-8 flex flex-col gap-5">

          <!-- Row 1: Name + Email side by side -->
          <div class="flex flex-col md:flex-row gap-4">

            <!-- Name field -->
            <div class="flex-1 flex flex-col gap-1.5">
              <label class="text-[13px] font-medium text-[var(--text-heading)]" for="contact-name">Nombre</label>
              <input
                id="contact-name"
                type="text"
                placeholder="Tu nombre"
                class="h-11 rounded-[6px] border-[1.5px] border-[var(--border-default)] px-3.5 text-[14px] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] bg-[var(--bg-primary)] outline-none focus:border-[var(--color-primary-bg)] transition-colors"
              />
            </div>

            <!-- Email field -->
            <div class="flex-1 flex flex-col gap-1.5">
              <label class="text-[13px] font-medium text-[var(--text-heading)]" for="contact-email">Email</label>
              <input
                id="contact-email"
                type="email"
                placeholder="tu@email.com"
                class="h-11 rounded-[6px] border-[1.5px] border-[var(--border-default)] px-3.5 text-[14px] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] bg-[var(--bg-primary)] outline-none focus:border-[var(--color-primary-bg)] transition-colors"
              />
            </div>

          </div>

          <!-- Row 2: Message textarea -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[13px] font-medium text-[var(--text-heading)]" for="contact-message">Mensaje</label>
            <textarea
              id="contact-message"
              placeholder="Cuéntame sobre tu proyecto..."
              class="h-[120px] rounded-[6px] border-[1.5px] border-[var(--border-default)] p-3.5 text-[14px] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] bg-[var(--bg-primary)] outline-none focus:border-[var(--color-primary-bg)] transition-colors resize-none"
            ></textarea>
          </div>

          <!-- Submit button -->
          <button
            type="submit"
            class="w-full bg-[var(--color-primary-bg)] text-white text-[16px] font-semibold rounded-[6px] py-3.5 px-8 cursor-pointer hover:opacity-90 transition-opacity"
          >
            Enviar Mensaje
          </button>

        </form>
      </div>

      <!-- Right column: contact info card -->
      <div class="w-full md:w-[360px] md:flex-shrink-0">
        <div class="rounded-[8px] border-[1.5px] border-[var(--border-default)] p-8 flex flex-col gap-6">

          <!-- Card title -->
          <h3 class="text-[18px] font-semibold text-[var(--text-heading)]">Información de Contacto</h3>

          <!-- Contact rows -->
          <div class="flex flex-col gap-4">

            <!-- Email row -->
            <div class="flex items-center gap-3">
              <!-- lucide: mail -->
              <svg
                class="w-[20px] h-[20px] text-[var(--color-primary)] flex-shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              <span class="text-[14px] text-[var(--text-secondary)]">cmayorgahilario@gmail.com</span>
            </div>

            <!-- Phone row -->
            <div class="flex items-center gap-3">
              <!-- lucide: phone -->
              <svg
                class="w-[20px] h-[20px] text-[var(--color-primary)] flex-shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span class="text-[14px] text-[var(--text-secondary)]">+51 997 509 616</span>
            </div>

            <!-- Location row -->
            <div class="flex items-center gap-3">
              <!-- lucide: map-pin -->
              <svg
                class="w-[20px] h-[20px] text-[var(--color-primary)] flex-shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-[14px] text-[var(--text-secondary)]">Lima, Perú</span>
            </div>

          </div>

          <!-- Divider -->
          <div class="w-full h-px bg-[var(--border-default)]"></div>

          <!-- Availability badge -->
          <div class="bg-[var(--bg-green)] rounded-[8px] py-3 px-4 w-full flex items-center gap-2">
            <div class="w-2.5 h-2.5 rounded-full bg-[var(--color-green)] flex-shrink-0"></div>
            <span class="text-[14px] font-medium text-[var(--text-green)]">Disponible para proyectos</span>
          </div>

        </div>
      </div>

    </div>

  </div>
</section>
tion>
