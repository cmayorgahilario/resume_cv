---
// Proyectos section — 3×2 grid of project cards with alternating indigo/amber themes
---

<section id="proyectos" class="bg-[var(--bg-indigo-soft)] py-12 md:py-20 px-6 md:px-20">
  <div class="max-w-[1440px] mx-auto flex flex-col gap-12">

    <!-- Section header -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-3">
        <div class="w-8 h-[3px] bg-[var(--color-primary-bg)]"></div>
        <span class="text-xs font-semibold tracking-[3px] text-[var(--color-primary)]">PROYECTOS DESTACADOS</span>
      </div>
      <h2 class="text-[28px] md:text-[36px] font-bold tracking-[-0.5px] text-[var(--text-heading)]">
        Soluciones que generan impacto
      </h2>
      <p class="text-[15px] leading-[1.7] text-[var(--text-secondary)]">
        Proyectos clave donde apliqué arquitectura, liderazgo y tecnología para resolver problemas reales
      </p>
    </div>

    <!-- Row 1: Card 1 (Indigo) + Card 2 (Amber) -->
    <div class="flex flex-col md:flex-row gap-6 md:items-stretch">

      <!-- Card 1: Plataforma E-commerce Omnicanal — Indigo -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--color-primary)]">RETAIL & E-COMMERCE</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Plataforma E-commerce Omnicanal</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Implementación completa de plataforma e-commerce con servicios omnicanal en .NET y Java,
            diseñada para futura integración con aplicación móvil. Entrega en menos de 6 meses.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">.NET</span>
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Java</span>
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Microservicios</span>
          </div>
        </div>
        <div class="bg-[var(--bg-indigo-soft)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">&lt; 6 meses</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Tiempo de entrega</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">Omnicanal</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Arquitectura</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Gestión de Espacios Publicitarios — Amber -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--text-amber-accent)]">MEDIOS & PUBLICIDAD</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Gestión de Espacios Publicitarios</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Middleware para cotización y administración de espacios publicitarios con soporte para video
            y contenido estático.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Middleware</span>
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">API REST</span>
          </div>
        </div>
        <div class="bg-[var(--bg-amber)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Video + Estático</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Formatos soportados</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Multi-perfil</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Gestión de usuarios</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Row 2: Card 3 (Indigo) + Card 4 (Amber) -->
    <div class="flex flex-col md:flex-row gap-6 md:items-stretch">

      <!-- Card 3: Core de Facturación de Servicios — Indigo -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--color-primary)]">SERVICIOS & UTILIDADES</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Core de Facturación de Servicios</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Mejora del sistema central de administración y facturación para servicios de agua, electricidad
            y aire acondicionado.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Core System</span>
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Facturación</span>
          </div>
        </div>
        <div class="bg-[var(--bg-indigo-soft)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">3 servicios</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Integrados</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">Optimizado</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Proceso core</span>
          </div>
        </div>
      </div>

      <!-- Card 4: Nómina y Cálculo Presupuestal — Amber -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--text-amber-accent)]">GESTIÓN EMPRESARIAL</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Nómina y Cálculo Presupuestal</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Sistema de cálculo de presupuesto anual y procesamiento de pagos a empleados
            con Java, Spring Boot y Angular.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Java</span>
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Spring Boot</span>
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Angular</span>
          </div>
        </div>
        <div class="bg-[var(--bg-amber)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Anual</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Ciclo presupuestal</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Automatizado</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Proceso de nómina</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Row 3: Card 5 (Indigo) + Card 6 (Amber) -->
    <div class="flex flex-col md:flex-row gap-6 md:items-stretch">

      <!-- Card 5: Inspección Vehicular Automatizada — Indigo -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--color-primary)]">AUTOMATIZACIÓN</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Inspección Vehicular Automatizada</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Automatización del proceso de check-in vehicular con captura fotográfica en múltiples talleres.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Automatización</span>
            <span class="bg-[var(--bg-indigo-pill)] text-[var(--color-primary)] text-[11px] font-medium rounded px-2.5 py-1">Multi-taller</span>
          </div>
        </div>
        <div class="bg-[var(--bg-indigo-soft)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">0 errores</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Proceso manual</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--color-primary)]">Multi-sede</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Continuidad</span>
          </div>
        </div>
      </div>

      <!-- Card 6: Sistema de Balanced Scorecard — Amber -->
      <div class="flex-1 bg-[var(--bg-card)] rounded-[16px] p-7 border-[1.5px] border-[var(--border-default)] shadow-[0_2px_12px_#00000012] flex flex-col justify-between h-full">
        <div class="flex flex-col gap-3">
          <span class="text-[11px] font-semibold tracking-[1px] uppercase text-[var(--text-amber-accent)]">TRANSFORMACIÓN DIGITAL</span>
          <h3 class="text-lg font-bold text-[var(--text-heading)]">Sistema de Balanced Scorecard</h3>
          <p class="text-[13px] leading-[1.6] text-[var(--text-secondary)]">
            Modernización de sistema legacy de cuadro de mando integral, migrando a tecnologías actuales
            con Java Spring y Angular.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Java Spring</span>
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Angular</span>
            <span class="bg-[var(--bg-amber-pill)] text-[var(--text-amber-dark)] text-[11px] font-medium rounded px-2.5 py-1">Modernización</span>
          </div>
        </div>
        <div class="bg-[var(--bg-amber)] rounded-[10px] p-4 flex gap-6 mt-4">
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Legacy → Modern</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Migración completa</span>
          </div>
          <div class="flex flex-col">
            <span class="text-sm font-bold text-[var(--text-amber-accent)]">Mejorado</span>
            <span class="text-[11px] text-[var(--text-secondary)]">Rendimiento</span>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

</section>
  </div>
</section>
  </div>
</section>
