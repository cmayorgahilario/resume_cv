---
import { testimonials } from "../data/portfolio";
---

<section
  id="testimonials"
  class="max-w-[1280px] mx-auto px-6 md:px-10 py-20 md:py-24 border-b border-fp-line dark:border-fp-dline"
>
  <div class="grid grid-cols-12 gap-6 md:gap-10 mb-14">
    <div class="col-span-12 md:col-span-4">
      <div
        data-fi
        class="opacity-0 font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-3"
      >
        06 — Testimonios
      </div>
      <h2
        data-fi
        style="animation-delay:.05s"
        class="opacity-0 tracking-[-0.03em] text-4xl md:text-5xl font-light leading-tight"
      >
        Lo que dicen<br />
        <span class="text-fp-dim">mis líderes.</span>
      </h2>
    </div>
    <div class="col-span-12 md:col-span-8">
      <p
        data-fi
        class="opacity-0 text-lg text-fp-dim dark:text-fp-ddim leading-relaxed max-w-2xl"
      >
        Referencias verificables de quienes lideraron equipos conmigo o me
        tuvieron como referencia técnica.
      </p>
    </div>
  </div>
  <div
    class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-fp-line dark:border-fp-dline"
  >
    {
      testimonials.map((t, i) => {
        const classes = [
          "opacity-0",
          "p-8",
          "md:p-10",
          "transition-colors",
          "duration-300",
          "hover:bg-fp-panel",
          "dark:hover:bg-fp-dpanel",
          "flex",
          "flex-col",
          i < 2 ? "md:border-r" : "",
          i < testimonials.length - 1 ? "border-b md:border-b-0" : "",
          "border-fp-line",
          "dark:border-fp-dline",
        ]
          .filter(Boolean)
          .join(" ");
        return (
          <article
            class={classes}
            data-fi
            style={`animation-delay:${i * 0.08}s`}
          >
            <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-6 flex items-center gap-2">
              <span class="inline-block w-6 h-px bg-fp-ink dark:bg-fp-dfg" />
              <span>
                {String(i + 1).padStart(2, "0")} /{" "}
                {String(testimonials.length).padStart(2, "0")}
              </span>
            </div>
            <div class="tracking-[-0.03em] text-5xl leading-none text-fp-dim mb-4 -ml-1">
              "
            </div>
            <p class="tracking-[-0.03em] text-xl md:text-[22px] font-light leading-[1.4] text-fp-ink dark:text-fp-dfg mb-8 flex-1">
              {t.quote}
            </p>
            <div class="pt-5 border-t border-fp-line dark:border-fp-dline">
              <div class="tracking-[-0.03em] text-lg font-normal leading-tight">
                {t.name}
              </div>
              <div class="text-[13px] text-fp-dim dark:text-fp-ddim mt-1">
                {t.role} · {t.company}
              </div>
              <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mt-2">
                {t.period}
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>
