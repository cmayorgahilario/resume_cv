---
import { projects } from "../data/portfolio";
---

<section
  id="projects"
  class="max-w-[1280px] mx-auto px-6 md:px-10 py-20 md:py-24 border-b border-fp-line dark:border-fp-dline"
>
  <div class="grid grid-cols-12 gap-6 md:gap-10 mb-14">
    <div class="col-span-12 md:col-span-4">
      <div
        data-fi
        class="opacity-0 font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-3"
      >
        03 — Proyectos
      </div>
      <h2
        data-fi
        style="animation-delay:.05s"
        class="opacity-0 tracking-[-0.03em] text-4xl md:text-5xl font-light leading-tight"
      >
        Proyectos destacados
      </h2>
    </div>
    <div class="col-span-12 md:col-span-8">
      <p
        data-fi
        class="opacity-0 text-lg text-fp-dim dark:text-fp-ddim leading-relaxed max-w-2xl"
      >
        Cuatro casos clave del periodo 2022-2024 en Real Plaza, cada uno con
        desafío, solución y resultados cuantificables.
      </p>
    </div>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-2 gap-0 border border-fp-line dark:border-fp-dline"
  >
    {
      projects.map((p, i) => {
        const classes = [
          "opacity-0",
          "p-8",
          "md:p-10",
          "transition-colors",
          "duration-300",
          "hover:bg-fp-panel",
          "dark:hover:bg-fp-dpanel",
          i < 2 ? "border-b" : "",
          i % 2 === 0 ? "md:border-r" : "",
          "border-fp-line",
          "dark:border-fp-dline",
        ]
          .filter(Boolean)
          .join(" ");
        return (
          <article
            class={classes}
            data-fi
            style={`animation-delay:${i * 0.06}s`}
          >
            <div class="flex items-start justify-between mb-5">
              <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium">
                Proyecto · {String(i + 1).padStart(2, "0")}
              </div>
              <div class="font-mono text-xs text-fp-dim">{p.period}</div>
            </div>
            <h3 class="tracking-[-0.03em] text-2xl md:text-3xl font-light leading-tight mb-4">
              {p.title}
            </h3>
            <p class="text-[15px] leading-relaxed text-fp-ink2 dark:text-fp-dfg/85 mb-8">
              {p.desc}
            </p>
            <div class="grid grid-cols-3 gap-4 py-5 border-y border-fp-line dark:border-fp-dline mb-6">
              {p.results.map((r) => (
                <div>
                  <div class="tracking-[-0.03em] text-xl font-light font-mono tabular-nums">
                    {r[0]}
                  </div>
                  <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mt-1">
                    {r[1]}
                  </div>
                </div>
              ))}
            </div>
            <div class="flex flex-wrap gap-1.5">
              {p.stack.map((s) => (
                <span class="inline-flex items-center gap-1 font-mono text-[11px] px-2.5 py-1 bg-fp-line2 text-fp-ink2 dark:bg-fp-dline2 dark:text-fp-dfg">
                  {s}
                </span>
              ))}
            </div>
          </article>
        );
      })
    }
  </div>
</section>
