---
---

<section
  id="contact"
  class="max-w-[1280px] mx-auto px-6 md:px-10 py-20 md:py-28 border-b border-fp-line dark:border-fp-dline"
>
  <div class="grid grid-cols-12 gap-6 md:gap-10">
    <div class="col-span-12 md:col-span-6">
      <div
        data-fi
        class="opacity-0 font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-6"
      >
        08 — Contacto
      </div>
      <h2
        data-fi
        style="animation-delay:.05s"
        class="opacity-0 tracking-[-0.03em] text-5xl md:text-7xl font-light leading-[0.98] mb-8"
      >
        Conversemos<br />
        <span class="text-fp-dim">sobre tu próximo</span><br />
        proyecto.
      </h2>
      <p
        data-fi
        style="animation-delay:.1s"
        class="opacity-0 text-lg text-fp-dim dark:text-fp-ddim leading-relaxed max-w-lg mb-10"
      >
        Respondo en menos de 12 horas. Disponibilidad inmediata para
        entrevistas, consultas técnicas o conversaciones sobre arquitectura.
      </p>

      <div
        data-fi
        style="animation-delay:.15s"
        class="opacity-0 flex items-center gap-3 mb-10"
      >
        <span
          class="inline-block w-2 h-2 bg-green-600 rounded-full animate-pulse-dot"
        ></span>
        <span
          class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium"
          >Disponible · inmediata</span
        >
      </div>

      <a
        href="mailto:cmayorgahilario@gmail.com"
        class="inline-flex items-center gap-3 px-8 py-4 bg-fp-ink text-fp-bg dark:bg-fp-dfg dark:text-fp-dbg text-base font-medium hover:opacity-80 transition-opacity group"
      >
        Enviar mensaje
        <svg
          class="w-4 h-4 group-hover:translate-x-1 transition-transform"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
    </div>

    <div
      class="opacity-0 col-span-12 md:col-span-6"
      data-fi
      style="animation-delay:.15s"
    >
      <div
        class="border border-fp-line dark:border-fp-dline divide-y divide-fp-line dark:divide-fp-dline"
      >
        <a
          href="mailto:cmayorgahilario@gmail.com"
          class="flex items-center justify-between p-6 transition-colors duration-300 hover:bg-fp-panel dark:hover:bg-fp-dpanel group"
        >
          <div>
            <div
              class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-1"
            >
              Email
            </div>
            <div class="text-base font-medium">
              cmayorgahilario@gmail.com
            </div>
          </div>
          <svg
            class="w-4 h-4 text-fp-dim group-hover:text-fp-ink dark:group-hover:text-fp-dfg group-hover:translate-x-1 transition-all"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M7 17L17 7M7 7h10v10"></path>
          </svg>
        </a>
        <a
          href="tel:+51997509616"
          class="flex items-center justify-between p-6 transition-colors duration-300 hover:bg-fp-panel dark:hover:bg-fp-dpanel group"
        >
          <div>
            <div
              class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-1"
            >
              Teléfono
            </div>
            <div class="text-base font-medium">+51 997 509 616</div>
          </div>
          <svg
            class="w-4 h-4 text-fp-dim group-hover:text-fp-ink dark:group-hover:text-fp-dfg group-hover:translate-x-1 transition-all"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M7 17L17 7M7 7h10v10"></path>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/cmayorgahilario/"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-between p-6 transition-colors duration-300 hover:bg-fp-panel dark:hover:bg-fp-dpanel group"
        >
          <div>
            <div
              class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-1"
            >
              LinkedIn
            </div>
            <div class="text-base font-medium">/in/cmayorgahilario</div>
          </div>
          <svg
            class="w-4 h-4 text-fp-dim group-hover:text-fp-ink dark:group-hover:text-fp-dfg group-hover:translate-x-1 transition-all"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M7 17L17 7M7 7h10v10"></path>
          </svg>
        </a>
        <a
          href="https://github.com/cmayorgahilario"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-between p-6 transition-colors duration-300 hover:bg-fp-panel dark:hover:bg-fp-dpanel group"
        >
          <div>
            <div
              class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-1"
            >
              GitHub
            </div>
            <div class="text-base font-medium">@cmayorgahilario</div>
          </div>
          <svg
            class="w-4 h-4 text-fp-dim group-hover:text-fp-ink dark:group-hover:text-fp-dfg group-hover:translate-x-1 transition-all"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M7 17L17 7M7 7h10v10"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
