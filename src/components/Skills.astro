---
import { skills } from "../data/portfolio";
---

<section
  id="skills"
  class="max-w-[1280px] mx-auto px-6 md:px-10 py-20 md:py-24 border-b border-fp-line dark:border-fp-dline"
>
  <div class="grid grid-cols-12 gap-6 md:gap-10 mb-14">
    <div class="col-span-12 md:col-span-4">
      <div
        data-fi
        class="opacity-0 font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-3"
      >
        04 — Stack
      </div>
      <h2
        data-fi
        style="animation-delay:.05s"
        class="opacity-0 tracking-[-0.03em] text-4xl md:text-5xl font-light leading-tight"
      >
        Competencias técnicas
      </h2>
    </div>
    <div class="col-span-12 md:col-span-8">
      <p
        data-fi
        class="opacity-0 text-lg text-fp-dim dark:text-fp-ddim leading-relaxed max-w-2xl"
      >
        Stack consolidado tras una década de decisiones iterativas. Profundidad
        en backend, arquitectura y cloud; competencia sólida en frontend
        moderno.
      </p>
    </div>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0 border border-fp-line dark:border-fp-dline"
  >
    {
      skills.map((s, i) => {
        const isLastCol = (i + 1) % 3 === 0;
        const isLastRow = i >= skills.length - 3;
        const classes = [
          "opacity-0",
          "p-7",
          "md:p-8",
          "transition-colors",
          "duration-300",
          "hover:bg-fp-panel",
          "dark:hover:bg-fp-dpanel",
          "flex",
          "flex-col",
          !isLastCol ? "lg:border-r" : "",
          !isLastRow ? "border-b" : "",
          "md:border-b",
          "border-fp-line",
          "dark:border-fp-dline",
        ]
          .filter(Boolean)
          .join(" ");
        return (
          <div
            class={classes}
            data-fi
            style={`animation-delay:${i * 0.03}s`}
          >
            <div class="flex items-center justify-between mb-5">
              <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium">
                {String(i + 1).padStart(2, "0")} — {s.cat}
              </div>
              <div class="font-mono text-[10px] text-fp-dim">
                {s.items.length} items
              </div>
            </div>
            <p class="text-[13px] leading-relaxed text-fp-dim dark:text-fp-ddim mb-6 pb-5 border-b border-fp-line2 dark:border-fp-dline2">
              {s.evidence}
            </p>
            <ul class="space-y-3 flex-1">
              {s.items.map((it) => (
                <li>
                  <div
                    class={`flex items-baseline justify-between gap-3 ${it[3] ? "mb-1" : ""}`}
                  >
                    <span class="font-medium text-[14px] flex items-center gap-2">
                      {it[3] ? (
                        <span class="inline-block w-1 h-1 bg-fp-ink dark:bg-fp-dfg rounded-full" />
                      ) : (
                        <span class="inline-block w-1 h-1" />
                      )}
                      {it[0]}
                    </span>
                    <span class="font-mono text-[11px] tabular-nums text-fp-dim whitespace-nowrap">
                      {it[1]}
                    </span>
                  </div>
                  {it[3] && (
                    <div class="font-mono text-[11px] leading-relaxed text-fp-dim dark:text-fp-ddim pl-3">
                      {it[2]}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        );
      })
    }
  </div>
</section>
