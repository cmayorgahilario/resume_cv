---
import { values } from "../data/portfolio";
---

<section
  id="values"
  class="max-w-[1280px] mx-auto px-6 md:px-10 py-20 md:py-24 border-b border-fp-line dark:border-fp-dline"
>
  <div class="grid grid-cols-12 gap-6 md:gap-10 mb-14">
    <div class="col-span-12 md:col-span-4">
      <div
        data-fi
        class="opacity-0 font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-3"
      >
        07 — Principios
      </div>
      <h2
        data-fi
        style="animation-delay:.05s"
        class="opacity-0 tracking-[-0.03em] text-4xl md:text-5xl font-light leading-tight"
      >
        Qué defiendo
      </h2>
    </div>
    <div class="col-span-12 md:col-span-8">
      <p
        data-fi
        class="opacity-0 text-lg text-fp-dim dark:text-fp-ddim leading-relaxed max-w-2xl"
      >
        Cuatro principios innegociables. Los aplico en cada decisión técnica y
        de liderazgo.
      </p>
    </div>
  </div>

  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0 border border-fp-line dark:border-fp-dline"
  >
    {
      values.map((v, i) => {
        const isLastCol = (i + 1) % 4 === 0;
        const classes = [
          "opacity-0",
          "p-8",
          "transition-colors",
          "duration-300",
          "hover:bg-fp-panel",
          "dark:hover:bg-fp-dpanel",
          !isLastCol ? "lg:border-r" : "",
          i < values.length - 1 ? "border-b lg:border-b-0" : "",
          "border-fp-line",
          "dark:border-fp-dline",
        ]
          .filter(Boolean)
          .join(" ");
        return (
          <article
            class={classes}
            data-fi
            style={`animation-delay:${i * 0.05}s`}
          >
            <div class="font-mono text-[10px] tracking-[0.15em] uppercase text-fp-dim font-medium mb-5">
              {String(i + 1).padStart(2, "0")}
            </div>
            <h3 class="tracking-[-0.03em] text-2xl font-light leading-tight mb-3">
              {v.title}
            </h3>
            <p class="text-[14px] leading-relaxed text-fp-dim dark:text-fp-ddim">
              {v.desc}
            </p>
          </article>
        );
      })
    }
  </div>
</section>
