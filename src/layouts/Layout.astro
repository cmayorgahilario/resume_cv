---
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <!-- FOUC prevention: apply dark class before first paint -->
    <script is:inline>if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Inter font from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>Carlos Mayorga — Ingeniero de Software</title>
    <meta name="description" content="Portfolio profesional de Carlos Mayorga, Ingeniero de Software Senior especializado en Java y tecnologías enterprise." />
  </head>
  <body>
    <slot />
  </body>
</html>
