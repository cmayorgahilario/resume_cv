---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Carlos Mayorga Hilario · Software Engineering Lead",
  description = "Software Engineering Lead con 10+ años diseñando arquitecturas de microservicios, cloud-native y liderazgo técnico.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const stored = localStorage.getItem("theme-v12");
      if (
        stored === "dark" ||
        (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)
      ) {
        document.documentElement.classList.add("dark");
      }
    </script>
    <title>{title}</title>
  </head>
  <body
    class="bg-fp-bg dark:bg-fp-dbg text-fp-ink dark:text-fp-dfg font-sans antialiased text-[15px] tracking-[-0.011em] [font-feature-settings:'cv11','ss01','tnum','calt'] selection:bg-fp-accent selection:text-white"
  >
    <div
      id="progress"
      class="fixed top-0 inset-x-0 h-0.5 z-[100] bg-fp-ink dark:bg-fp-dfg origin-left scale-x-0"
    >
    </div>
    <slot />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
