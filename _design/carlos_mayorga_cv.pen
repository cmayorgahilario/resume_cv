                        },
                        {
                          "type": "text",
                          "id": "QJ0nt",
                          "name": "gc1v",
                          "fill": "#9CA3AF",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Framer Motion (React) — recomendada. Ofrece whileInView, AnimatePresence, useScroll, variants y spring physics. AOS como alternativa para vanilla JS/HTML. Intersection Observer API nativo como fallback ligero.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "zV4rH",
                      "name": "gCol2",
                      "width": "fill_container",
