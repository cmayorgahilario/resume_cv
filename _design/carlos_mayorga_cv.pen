                          "name": "gc3t",
                          "fill": "#818CF8",
                          "content": "Performance",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "MPtzJ",
                          "name": "gc3v",
                          "fill": "#9CA3AF",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Solo animar transform y opacity (GPU accelerated).\nEvitar animating layout properties (width, height, top).\nUsar will-change: transform en elementos animados.\nLazy-load animations fuera del viewport inicial.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
