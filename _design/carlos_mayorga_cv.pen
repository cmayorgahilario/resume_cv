                      "layout": "vertical",
                      "gap": 12,
                      "padding": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "yKoqS",
                          "name": "gc2t",
                          "fill": "#818CF8",
                          "content": "Principios de motion",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "D6Cr6",
                          "name": "gc2v",
                          "fill": "#9CA3AF",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "prefers-reduced-motion: disable all animations.\nNo animation > 1s duration (excepto countUp).\nEasing: ease-out para entradas, ease-in-out para hover.\nStagger max 0.2s entre elementos.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
